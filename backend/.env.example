# Crea una cuenta gratuita en https://console.groq.com y genera tu API key
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Modelo de Groq (puedes cambiarlo por mixtral-8x7b-32768 si prefieres)
GROQ_MODEL=llama3-70b-8192

# Modelo de embeddings (se descarga automáticamente la primera vez, ~90 MB)
EMBED_MODEL=all-MiniLM-L6-v2
