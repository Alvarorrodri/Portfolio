# Crea una cuenta gratuita en https://console.groq.com y genera tu API key
GROQ_API_KEY=gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Modelo de Groq
GROQ_MODEL=llama3-70b-8192

# Modelo de embeddings (se descarga automáticamente la primera vez, ~90 MB)
EMBED_MODEL=all-MiniLM-L6-v2

# Entorno: development | production
# En production desactiva /docs y /redoc
ENV=development

# Orígenes permitidos en CORS (separados por coma, sin espacios)
# En producción pon tu dominio real: https://tuportfolio.com
CORS_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost
